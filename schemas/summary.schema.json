{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sonchanggi.github.io/fearNgreed/schemas/summary.schema.json",
  "title": "Fear & Greed quant research summary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "contract",
    "projectId",
    "methodologyVersion",
    "generatedAt",
    "dataAsOf",
    "status",
    "coverage",
    "primaryEntities",
    "limitations",
    "sources",
    "automation",
    "payload"
  ],
  "properties": {
    "schemaVersion": {"const": 1},
    "contract": {"const": "quant-research-summary"},
    "projectId": {"const": "fearngreed"},
    "methodologyVersion": {"const": "fear-flow-v5"},
    "generatedAt": {"type": "string", "format": "date-time"},
    "dataAsOf": {"type": "string", "format": "date"},
    "status": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state",
        "label",
        "cadence",
        "expectedFreshnessDays",
        "freshnessBasis",
        "expectedDataAsOf",
        "sourceFreshnessPassed",
        "degradedReasons"
      ],
      "properties": {
        "state": {"enum": ["ok", "degraded", "stale", "unavailable"]},
        "label": {
          "enum": ["데이터 정상", "데이터 저하", "데이터 지연", "데이터 산출 불가"],
          "description": "Operational data state label; signal semantics live on primaryEntities."
        },
        "cadence": {"const": "weekdays-after-20:30-KST"},
        "expectedFreshnessDays": {"type": "integer", "minimum": 0, "maximum": 30},
        "freshnessBasis": {
          "enum": ["official_krx_latest_completed_session", "source_alignment_only"]
        },
        "expectedDataAsOf": {"type": ["string", "null"], "format": "date"},
        "sourceFreshnessPassed": {"type": "boolean"},
        "degradedReasons": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        }
      }
    },
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "historyStart",
        "historyEnd",
        "observationCount",
        "eventCount",
        "tradeCount",
        "dateOverlapRatio",
        "sourceCompleteness"
      ],
      "properties": {
        "historyStart": {"type": "string", "format": "date"},
        "historyEnd": {"type": "string", "format": "date"},
        "observationCount": {"type": "integer", "minimum": 0},
        "eventCount": {"type": "integer", "minimum": 0},
        "tradeCount": {"type": "integer", "minimum": 0},
        "dateOverlapRatio": {
          "anyOf": [
            {"type": "number", "minimum": 0, "maximum": 1},
            {"type": "null"}
          ],
          "description": "Jaccard overlap of KOSPI-price and participant-flow session dates."
        },
        "sourceCompleteness": {
          "anyOf": [
            {"type": "number", "minimum": 0, "maximum": 1},
            {"type": "null"}
          ],
          "deprecated": true,
          "description": "Compatibility alias for dateOverlapRatio; not a broad completeness score."
        }
      }
    },
    "primaryEntities": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": {"$ref": "#/$defs/primaryEntity"}
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/source"}
    },
    "automation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lastAttemptAt", "lastSuccessAt", "state"],
      "properties": {
        "lastAttemptAt": {"type": "string", "format": "date-time"},
        "lastSuccessAt": {
          "anyOf": [
            {"type": "string", "format": "date-time"},
            {"type": "null"}
          ]
        },
        "state": {"enum": ["ok", "degraded", "stale", "unavailable"]}
      }
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dashboardUrl", "historyUrl", "automationStatusUrl", "strategyComparisonUrl"],
      "properties": {
        "dashboardUrl": {"type": "string", "minLength": 1},
        "historyUrl": {"type": "string", "minLength": 1},
        "automationStatusUrl": {"type": "string", "minLength": 1},
        "strategyComparisonUrl": {"const": "./strategy-comparison.json"}
      }
    }
  },
  "$defs": {
    "nullableNumber": {
      "anyOf": [
        {"type": "number"},
        {"type": "null"}
      ]
    },
    "nullablePercent": {
      "anyOf": [
        {"type": "number", "minimum": 0, "maximum": 100},
        {"type": "null"}
      ]
    },
    "nullableRatio": {
      "anyOf": [
        {"type": "number", "minimum": 0, "maximum": 1},
        {"type": "null"}
      ]
    },
    "primaryEntity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "region",
        "themes",
        "signalState",
        "signalLabel",
        "sentimentPercentile",
        "residualZ",
        "rollingR2",
        "return1d",
        "flowShare",
        "rawFlowTrillion",
        "disparity50",
        "mdd252",
        "modelQuality",
        "modelConfidence",
        "models",
        "position",
        "positionQuality",
        "positionUnavailableReason",
        "pendingAction",
        "pendingReason",
        "primaryProxy",
        "sourceMode",
        "strategyModel",
        "fieldSources"
      ],
      "properties": {
        "id": {"const": "KOSPI"},
        "name": {"type": "string", "minLength": 1},
        "region": {"const": "Korea"},
        "themes": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "signalState": {
          "enum": ["extreme_fear", "fear", "neutral", "greed", "extreme_greed", "unavailable"]
        },
        "signalLabel": {
          "enum": ["극단적 공포", "공포", "중립", "탐욕", "극단적 탐욕", "산출 불가"]
        },
        "sentimentPercentile": {"$ref": "#/$defs/nullablePercent"},
        "residualZ": {"$ref": "#/$defs/nullableNumber"},
        "rollingR2": {"$ref": "#/$defs/nullableRatio"},
        "return1d": {
          "anyOf": [
            {"type": "number", "minimum": -1},
            {"type": "null"}
          ]
        },
        "flowShare": {"$ref": "#/$defs/nullableNumber"},
        "rawFlowTrillion": {"$ref": "#/$defs/nullableNumber"},
        "disparity50": {
          "anyOf": [
            {"type": "number", "exclusiveMinimum": 0},
            {"type": "null"}
          ]
        },
        "mdd252": {
          "anyOf": [
            {"type": "number", "minimum": -1, "maximum": 0},
            {"type": "null"}
          ]
        },
        "modelQuality": {
          "enum": [
            "ok",
            "low_model_fit",
            "duplicate_dates",
            "insufficient_history",
            "invalid_regression",
            "invalid_current_observation",
            "invalid_training_observation",
            "mixed_channels",
            "zero_mad",
            "missing"
          ]
        },
        "modelConfidence": {
          "enum": [
            "high",
            "mixed",
            "mixed_trigger",
            "scaled_only",
            "low_model_fit",
            "unavailable"
          ]
        },
        "models": {
          "type": "object",
          "additionalProperties": false,
          "required": ["scaled", "raw", "robust"],
          "properties": {
            "scaled": {"$ref": "#/$defs/modelSnapshot"},
            "raw": {"$ref": "#/$defs/modelSnapshot"},
            "robust": {"$ref": "#/$defs/modelSnapshot"}
          }
        },
        "position": {"enum": ["cash", "long", "unavailable"]},
        "positionQuality": {"enum": ["ok", "unavailable"]},
        "positionUnavailableReason": {
          "anyOf": [
            {"type": "string", "minLength": 1},
            {"type": "null"}
          ]
        },
        "pendingAction": {
          "anyOf": [
            {"enum": ["enter_next_open", "exit_next_open"]},
            {"type": "null"}
          ]
        },
        "pendingReason": {
          "anyOf": [
            {"enum": ["extreme_fear_entry", "recovery", "max_holding"]},
            {"type": "null"}
          ]
        },
        "primaryProxy": {"const": "069500"},
        "sourceMode": {"enum": ["krx_open_api", "authenticated_pykrx_fallback"]},
        "strategyModel": {"type": "string", "minLength": 1},
        "fieldSources": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kospi", "retailFlow", "adjustedProxy"],
          "properties": {
            "kospi": {"enum": ["krx_open_api", "authenticated_pykrx_fallback"]},
            "retailFlow": {"const": "authenticated_pykrx"},
            "adjustedProxy": {
              "enum": [
                "yfinance_adjusted",
                "yfinance_adjusted_plus_scaled_krx_gap_rows"
              ]
            }
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {"position": {"const": "unavailable"}},
            "required": ["position"]
          },
          "then": {
            "properties": {
              "positionQuality": {"const": "unavailable"},
              "positionUnavailableReason": {"type": "string", "minLength": 1}
            }
          },
          "else": {
            "properties": {
              "positionQuality": {"const": "ok"},
              "positionUnavailableReason": {"type": "null"}
            }
          }
        }
      ]
    },
    "modelSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model",
        "state",
        "percentile",
        "residual",
        "residualZ",
        "alpha",
        "beta",
        "rollingR2",
        "trainingCount",
        "quality",
        "tradeEligible",
        "expected",
        "observed",
        "fitMethod",
        "fitScore"
      ],
      "properties": {
        "model": {"enum": ["scaled", "raw", "robust"]},
        "state": {
          "enum": ["extreme_fear", "fear", "neutral", "greed", "extreme_greed", "unavailable"]
        },
        "percentile": {"$ref": "#/$defs/nullablePercent"},
        "residual": {"$ref": "#/$defs/nullableNumber"},
        "residualZ": {"$ref": "#/$defs/nullableNumber"},
        "alpha": {"$ref": "#/$defs/nullableNumber"},
        "beta": {"$ref": "#/$defs/nullableNumber"},
        "rollingR2": {"$ref": "#/$defs/nullableRatio"},
        "trainingCount": {"type": "integer", "minimum": 0, "maximum": 252},
        "quality": {
          "enum": [
            "ok",
            "low_model_fit",
            "duplicate_dates",
            "insufficient_history",
            "invalid_regression",
            "invalid_current_observation",
            "invalid_training_observation",
            "mixed_channels",
            "zero_mad",
            "missing"
          ]
        },
        "tradeEligible": {"type": "boolean"},
        "expected": {"$ref": "#/$defs/nullableNumber"},
        "observed": {"$ref": "#/$defs/nullableNumber"},
        "fitMethod": {"enum": ["ols", "huber", "tukey_bisquare"]},
        "fitScore": {"$ref": "#/$defs/nullableNumber"}
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "url"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "label": {"type": "string", "minLength": 1},
        "url": {"type": "string", "format": "uri"},
        "mode": {"enum": ["krx_open_api", "authenticated_pykrx_fallback"]}
      }
    }
  }
}
